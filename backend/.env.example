# ─── Base de données (Supabase PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# ─── Auth ────────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-random-one
HMAC_SECRET=your-hmac-secret-here-generate-a-random-one

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── N8n Webhooks ────────────────────────────────────────────────────────────
# En production (Docker) : utiliser le nom du service docker
N8N_WEBHOOK_URL=http://n8n:5678/webhook/chef-validation
N8N_COMPANY_WEBHOOK_URL=http://n8n:5678/webhook/company-decision

# ─── URLs de l'application ───────────────────────────────────────────────────
# En production : mettre l'IP publique ou le nom de domaine EC2
FRONTEND_URL=https://enimconnect.duckdns.org
BACKEND_URL=https://enimconnect.duckdns.org

# ─── Stockage fichiers ───────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ─── Emails des chefs de département (pour seed_chefs.py) ────────────────────
CHEF_INFO_EMAIL=chef.info@ensmr.ac.ma
CHEF_MAT_EMAIL=chef.mat@ensmr.ac.ma
CHEF_EM_EMAIL=chef.em@ensmr.ac.ma
CHEF_GI_EMAIL=chef.gi@ensmr.ac.ma
CHEF_GPI_EMAIL=chef.gpi@ensmr.ac.ma
CHEF_ST_EMAIL=chef.st@ensmr.ac.ma
CHEF_MINES_EMAIL=chef.mines@ensmr.ac.ma

# ─── SMTP pour N8n ───────────────────────────────────────────────────────────
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=587
N8N_SMTP_USER=votre-email@gmail.com
N8N_SMTP_PASS=votre-mot-de-passe-application
N8N_SMTP_SENDER=noreply@enimconnect.ma
N8N_SMTP_SSL=false
